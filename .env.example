# Copy this file to .env and fill in real values before running docker compose

POSTGRES_DB=ballgame
POSTGRES_USER=ballgame
POSTGRES_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-this-to-a-long-random-string

# Space-separated list of hostnames/IPs that Django will accept requests for
# Add your server's IP or domain name here for production
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Comma-separated origins Django will accept CSRF tokens from
# Set to your actual URL in production, e.g. http://192.168.1.100 or https://yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost
