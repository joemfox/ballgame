# Copy this file to .env and fill in real values before running docker compose

POSTGRES_DB=ballgame
POSTGRES_USER=ballgame
# Use a strong random password in production
POSTGRES_PASSWORD=changeme

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-this-to-a-long-random-string

# Space-separated list of hostnames/IPs that Django will accept requests for
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1

# Your server's public domain name — used by Caddy for TLS and by Django for CSRF
# Must be set to a real domain for HTTPS to work (Caddy will obtain a Let's Encrypt cert)
DOMAIN=yourdomain.com

# Must match DOMAIN (https:// prefix required for CSRF to work over HTTPS)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
